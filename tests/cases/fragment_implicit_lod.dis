OpCapability Shader
%2 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint Fragment %1 "MAIN"
OpExecutionMode %1 OriginUpperLeft
OpDecorate %3 DescriptorSet 0
OpDecorate %3 Binding 0
%float = OpTypeFloat 32
%5 = OpTypeImage %float 2D 0 0 0 1 Unknown
%6 = OpTypeSampledImage %5
%_ptr_UniformConstant_6 = OpTypePointer UniformConstant %6
%3 = OpVariable %_ptr_UniformConstant_6 UniformConstant
%void = OpTypeVoid
%9 = OpTypeFunction %void
%v2float = OpTypeVector %float 2
%_ptr_Private_v2float = OpTypePointer Private %v2float
%float_0_5 = OpConstant %float 0.5
%14 = OpConstantComposite %v2float %float_0_5 %float_0_5
%11 = OpVariable %_ptr_Private_v2float Private %14
%v4float = OpTypeVector %float 4
%_ptr_Private_v4float = OpTypePointer Private %v4float
%16 = OpVariable %_ptr_Private_v4float Private
%1 = OpFunction %void None %9
%18 = OpLabel
%19 = OpLoad %v2float %11
%20 = OpLoad %6 %3
%21 = OpImageSampleImplicitLod %v4float %20 %19
OpStore %16 %21
OpReturn
OpFunctionEnd
