OpCapability Shader
OpCapability Sampled1D
OpCapability Image1D
OpCapability ImageQuery
%2 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint GLCompute %1 "MAIN"
OpExecutionMode %1 LocalSize 64 1 1
OpDecorate %3 DescriptorSet 0
OpDecorate %3 Binding 0
OpDecorate %4 DescriptorSet 0
OpDecorate %4 Binding 1
OpDecorate %5 DescriptorSet 0
OpDecorate %5 Binding 2
%float = OpTypeFloat 32
%7 = OpTypeImage %float 1D 0 0 0 1 Unknown
%8 = OpTypeSampledImage %7
%_ptr_UniformConstant_8 = OpTypePointer UniformConstant %8
%3 = OpVariable %_ptr_UniformConstant_8 UniformConstant
%10 = OpTypeImage %float 2D 0 0 0 1 Unknown
%11 = OpTypeSampledImage %10
%_ptr_UniformConstant_11 = OpTypePointer UniformConstant %11
%4 = OpVariable %_ptr_UniformConstant_11 UniformConstant
%13 = OpTypeImage %float 3D 0 0 0 1 Unknown
%14 = OpTypeSampledImage %13
%_ptr_UniformConstant_14 = OpTypePointer UniformConstant %14
%5 = OpVariable %_ptr_UniformConstant_14 UniformConstant
%void = OpTypeVoid
%17 = OpTypeFunction %void
%int = OpTypeInt 32 1
%_ptr_Private_int = OpTypePointer Private %int
%19 = OpVariable %_ptr_Private_int Private
%v2int = OpTypeVector %int 2
%_ptr_Private_v2int = OpTypePointer Private %v2int
%22 = OpVariable %_ptr_Private_v2int Private
%v3int = OpTypeVector %int 3
%_ptr_Private_v3int = OpTypePointer Private %v3int
%25 = OpVariable %_ptr_Private_v3int Private
%int_0 = OpConstant %int 0
%int_1 = OpConstant %int 1
%1 = OpFunction %void None %17
%27 = OpLabel
%28 = OpLoad %8 %3
%30 = OpImage %7 %28
%29 = OpImageQuerySizeLod %int %30 %int_0
OpStore %19 %29
%32 = OpLoad %11 %4
%34 = OpImage %10 %32
%33 = OpImageQuerySizeLod %v2int %34 %int_0
OpStore %22 %33
%35 = OpLoad %14 %5
%37 = OpImage %13 %35
%36 = OpImageQuerySizeLod %v3int %37 %int_1
OpStore %25 %36
OpReturn
OpFunctionEnd
