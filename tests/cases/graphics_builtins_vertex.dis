OpCapability Shader
OpCapability DrawParameters
%2 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint Vertex %1 "MAIN" %3 %4 %gl_BaseInstance %6
OpDecorate %3 BuiltIn DrawIndex
OpDecorate %4 BuiltIn BaseVertex
OpDecorate %gl_BaseInstance BuiltIn BaseInstance
OpDecorate %6 Location 0
%void = OpTypeVoid
%8 = OpTypeFunction %void
%int = OpTypeInt 32 1
%_ptr_Input_int = OpTypePointer Input %int
%3 = OpVariable %_ptr_Input_int Input
%4 = OpVariable %_ptr_Input_int Input
%gl_BaseInstance = OpVariable %_ptr_Input_int Input
%v3int = OpTypeVector %int 3
%_ptr_Output_v3int = OpTypePointer Output %v3int
%6 = OpVariable %_ptr_Output_v3int Output
%_ptr_Output_int = OpTypePointer Output %int
%int_0 = OpConstant %int 0
%int_1 = OpConstant %int 1
%int_2 = OpConstant %int 2
%1 = OpFunction %void None %8
%13 = OpLabel
%14 = OpLoad %int %3
%17 = OpAccessChain %_ptr_Output_int %6 %int_0
OpStore %17 %14
%18 = OpLoad %int %4
%20 = OpAccessChain %_ptr_Output_int %6 %int_1
OpStore %20 %18
%21 = OpLoad %int %gl_BaseInstance
%23 = OpAccessChain %_ptr_Output_int %6 %int_2
OpStore %23 %21
OpReturn
OpFunctionEnd
