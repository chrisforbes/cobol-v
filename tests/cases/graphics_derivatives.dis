OpCapability Shader
%2 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint Fragment %1 "MAIN" %3 %4
OpExecutionMode %1 OriginUpperLeft
OpDecorate %3 Location 0
OpDecorate %4 Location 0
%void = OpTypeVoid
%6 = OpTypeFunction %void
%float = OpTypeFloat 32
%v4float = OpTypeVector %float 4
%_ptr_Input_v4float = OpTypePointer Input %v4float
%3 = OpVariable %_ptr_Input_v4float Input
%_ptr_Output_v4float = OpTypePointer Output %v4float
%4 = OpVariable %_ptr_Output_v4float Output
%_ptr_Private_v4float = OpTypePointer Private %v4float
%11 = OpVariable %_ptr_Private_v4float Private
%13 = OpVariable %_ptr_Private_v4float Private
%14 = OpVariable %_ptr_Private_v4float Private
%int = OpTypeInt 32 1
%1 = OpFunction %void None %6
%15 = OpLabel
%16 = OpLoad %v4float %3
%17 = OpDPdx %v4float %16
OpStore %11 %17
%18 = OpLoad %v4float %3
%19 = OpDPdy %v4float %18
OpStore %13 %19
%20 = OpLoad %v4float %3
%21 = OpFwidth %v4float %20
OpStore %14 %21
%22 = OpLoad %v4float %11
%23 = OpLoad %v4float %13
%25 = OpFAdd %v4float %22 %23
%26 = OpLoad %v4float %14
%27 = OpFAdd %v4float %25 %26
OpStore %4 %27
OpReturn
OpFunctionEnd
