OpCapability Shader
%2 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint GLCompute %1 "MAIN"
OpExecutionMode %1 LocalSize 1 1 1
%void = OpTypeVoid
%4 = OpTypeFunction %void
%float = OpTypeFloat 32
%_ptr_Private_float = OpTypePointer Private %float
%float_1 = OpConstant %float 1
%6 = OpVariable %_ptr_Private_float Private %float_1
%float_2 = OpConstant %float 2
%9 = OpVariable %_ptr_Private_float Private %float_2
%11 = OpVariable %_ptr_Private_float Private
%bool = OpTypeBool
%int = OpTypeInt 32 1
%float_10 = OpConstant %float 10
%float_20 = OpConstant %float 20
%float_40 = OpConstant %float 40
%float_30 = OpConstant %float 30
%1 = OpFunction %void None %4
%12 = OpLabel
%14 = OpLoad %float %6
%15 = OpLoad %float %9
%17 = OpFOrdLessThan %bool %14 %15
OpSelectionMerge %19 None
OpBranchConditional %17 %18 %19
%18 = OpLabel
OpStore %11 %float_10
OpBranch %19
%19 = OpLabel
%21 = OpLoad %float %6
%22 = OpLoad %float %9
%23 = OpFOrdGreaterThan %bool %21 %22
OpSelectionMerge %26 None
OpBranchConditional %23 %24 %25
%24 = OpLabel
OpStore %11 %float_20
OpBranch %26
%25 = OpLabel
%28 = OpLoad %float %6
%29 = OpFOrdEqual %bool %28 %float_1
OpSelectionMerge %32 None
OpBranchConditional %29 %30 %31
%30 = OpLabel
OpStore %11 %float_40
OpBranch %32
%31 = OpLabel
OpStore %11 %float_30
OpBranch %32
%32 = OpLabel
OpBranch %26
%26 = OpLabel
OpReturn
OpFunctionEnd
