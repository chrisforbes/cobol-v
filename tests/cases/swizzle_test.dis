OpCapability Shader
%2 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint GLCompute %1 "MAIN"
OpExecutionMode %1 LocalSize 1 1 1
%void = OpTypeVoid
%4 = OpTypeFunction %void
%int = OpTypeInt 32 1
%v4int = OpTypeVector %int 4
%_ptr_Private_v4int = OpTypePointer Private %v4int
%7 = OpVariable %_ptr_Private_v4int Private
%_ptr_Private_int = OpTypePointer Private %int
%9 = OpVariable %_ptr_Private_int Private
%int_1 = OpConstant %int 1
%int_0 = OpConstant %int 0
%int_2 = OpConstant %int 2
%int_3 = OpConstant %int 3
%int_4 = OpConstant %int 4
%v2int = OpTypeVector %int 2
%1 = OpFunction %void None %4
%11 = OpLabel
%14 = OpAccessChain %_ptr_Private_int %7 %int_0
OpStore %14 %int_1
%16 = OpAccessChain %_ptr_Private_int %7 %int_1
OpStore %16 %int_2
%18 = OpAccessChain %_ptr_Private_int %7 %int_2
OpStore %18 %int_3
%20 = OpAccessChain %_ptr_Private_int %7 %int_3
OpStore %20 %int_4
%21 = OpLoad %v4int %7
%22 = OpCompositeExtract %int %21 0
OpStore %9 %22
%24 = OpLoad %v4int %7
%25 = OpVectorShuffle %v2int %24 %24 2 3
%26 = OpLoad %v4int %7
%27 = OpVectorShuffle %v4int %26 %25 4 5 2 3
OpStore %7 %27
OpReturn
OpFunctionEnd
