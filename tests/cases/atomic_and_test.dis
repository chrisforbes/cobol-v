OpCapability Shader
%2 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint GLCompute %1 "MAIN"
OpExecutionMode %1 LocalSize 1 1 1
OpDecorate %3 DescriptorSet 0
OpDecorate %3 Binding 0
%uint = OpTypeInt 32 0
%5 = OpTypeImage %uint 2D 0 0 0 2 R32ui
%_ptr_UniformConstant_5 = OpTypePointer UniformConstant %5
%3 = OpVariable %_ptr_UniformConstant_5 UniformConstant
%void = OpTypeVoid
%8 = OpTypeFunction %void
%int = OpTypeInt 32 1
%v2int = OpTypeVector %int 2
%_ptr_Private_v2int = OpTypePointer Private %v2int
%11 = OpVariable %_ptr_Private_v2int Private
%int_0 = OpConstant %int 0
%float = OpTypeFloat 32
%_ptr_Image_uint = OpTypePointer Image %uint
%uint_15 = OpConstant %uint 15
%int_1 = OpConstant %int 1
%1 = OpFunction %void None %8
%13 = OpLabel
%15 = OpCompositeConstruct %v2int %int_0 %int_0
OpStore %11 %15
%17 = OpLoad %v2int %11
%19 = OpImageTexelPointer %_ptr_Image_uint %3 %17 %int_0
%22 = OpAtomicAnd %uint %19 %int_1 %int_0 %uint_15
OpReturn
OpFunctionEnd
