OpCapability Shader
OpCapability ImageCubeArray
OpCapability SampledCubeArray
%2 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint GLCompute %1 "MAIN"
OpExecutionMode %1 LocalSize 1 1 1
OpDecorate %3 DescriptorSet 0
OpDecorate %3 Binding 0
%float = OpTypeFloat 32
%5 = OpTypeImage %float Cube 0 1 0 1 Unknown
%6 = OpTypeSampledImage %5
%_ptr_UniformConstant_6 = OpTypePointer UniformConstant %6
%3 = OpVariable %_ptr_UniformConstant_6 UniformConstant
%void = OpTypeVoid
%9 = OpTypeFunction %void
%v4float = OpTypeVector %float 4
%_ptr_Private_v4float = OpTypePointer Private %v4float
%11 = OpVariable %_ptr_Private_v4float Private
%13 = OpVariable %_ptr_Private_v4float Private
%float_1 = OpConstant %float 1
%float_0 = OpConstant %float 0
%1 = OpFunction %void None %9
%14 = OpLabel
%17 = OpCompositeConstruct %v4float %float_1 %float_0 %float_0 %float_1
OpStore %11 %17
%18 = OpLoad %v4float %11
%19 = OpLoad %6 %3
%20 = OpImageSampleExplicitLod %v4float %19 %18 Lod %float_0
OpStore %13 %20
OpReturn
OpFunctionEnd
