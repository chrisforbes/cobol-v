OpCapability Shader
%2 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint GLCompute %1 "MAIN"
OpExecutionMode %1 LocalSize 1 1 1
%void = OpTypeVoid
%4 = OpTypeFunction %void
%int = OpTypeInt 32 1
%_ptr_Private_int = OpTypePointer Private %int
%int_5 = OpConstant %int 5
%6 = OpVariable %_ptr_Private_int Private %int_5
%int_3 = OpConstant %int 3
%9 = OpVariable %_ptr_Private_int Private %int_3
%11 = OpVariable %_ptr_Private_int Private
%12 = OpVariable %_ptr_Private_int Private
%13 = OpVariable %_ptr_Private_int Private
%14 = OpVariable %_ptr_Private_int Private
%15 = OpVariable %_ptr_Private_int Private
%16 = OpVariable %_ptr_Private_int Private
%float = OpTypeFloat 32
%int_1 = OpConstant %int 1
%1 = OpFunction %void None %4
%17 = OpLabel
%18 = OpLoad %int %6
%19 = OpLoad %int %9
%21 = OpBitwiseAnd %int %18 %19
OpStore %11 %21
%22 = OpLoad %int %6
%23 = OpLoad %int %9
%24 = OpBitwiseOr %int %22 %23
OpStore %12 %24
%25 = OpLoad %int %6
%26 = OpLoad %int %9
%27 = OpBitwiseXor %int %25 %26
OpStore %13 %27
%28 = OpLoad %int %6
%29 = OpNot %int %28
OpStore %14 %29
%30 = OpLoad %int %6
%32 = OpShiftLeftLogical %int %30 %int_1
OpStore %15 %32
%33 = OpLoad %int %6
%34 = OpShiftRightArithmetic %int %33 %int_1
OpStore %16 %34
OpReturn
OpFunctionEnd
