OpCapability Shader
OpCapability ImageQuery
%2 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint GLCompute %1 "MAIN"
OpExecutionMode %1 LocalSize 64 1 1
OpDecorate %3 DescriptorSet 0
OpDecorate %3 Binding 0
%float = OpTypeFloat 32
%5 = OpTypeImage %float 2D 0 0 0 1 Unknown
%6 = OpTypeSampledImage %5
%_ptr_UniformConstant_6 = OpTypePointer UniformConstant %6
%3 = OpVariable %_ptr_UniformConstant_6 UniformConstant
%void = OpTypeVoid
%9 = OpTypeFunction %void
%int = OpTypeInt 32 1
%v2int = OpTypeVector %int 2
%_ptr_Private_v2int = OpTypePointer Private %v2int
%12 = OpVariable %_ptr_Private_v2int Private
%int_1 = OpConstant %int 1
%1 = OpFunction %void None %9
%14 = OpLabel
%15 = OpLoad %6 %3
%17 = OpImage %5 %15
%16 = OpImageQuerySizeLod %v2int %17 %int_1
OpStore %12 %16
OpReturn
OpFunctionEnd
