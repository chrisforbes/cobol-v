OpCapability Shader
OpCapability Sampled1D
OpCapability Image1D
%2 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint GLCompute %1 "MAIN"
OpExecutionMode %1 LocalSize 1 1 1
OpDecorate %3 DescriptorSet 0
OpDecorate %3 Binding 0
%float = OpTypeFloat 32
%5 = OpTypeImage %float 1D 0 1 0 1 Unknown
%6 = OpTypeSampledImage %5
%_ptr_UniformConstant_6 = OpTypePointer UniformConstant %6
%3 = OpVariable %_ptr_UniformConstant_6 UniformConstant
%void = OpTypeVoid
%9 = OpTypeFunction %void
%v2float = OpTypeVector %float 2
%_ptr_Private_v2float = OpTypePointer Private %v2float
%11 = OpVariable %_ptr_Private_v2float Private
%v4float = OpTypeVector %float 4
%_ptr_Private_v4float = OpTypePointer Private %v4float
%14 = OpVariable %_ptr_Private_v4float Private
%float_0_5 = OpConstant %float 0.5
%float_1 = OpConstant %float 1
%float_0 = OpConstant %float 0
%1 = OpFunction %void None %9
%16 = OpLabel
%19 = OpCompositeConstruct %v2float %float_0_5 %float_1
OpStore %11 %19
%20 = OpLoad %v2float %11
%21 = OpLoad %6 %3
%22 = OpImageSampleExplicitLod %v4float %21 %20 Lod %float_0
OpStore %14 %22
OpReturn
OpFunctionEnd
