OpCapability Shader
%2 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint GLCompute %1 "MAIN"
OpExecutionMode %1 LocalSize 1 1 1
OpDecorate %3 DescriptorSet 0
OpDecorate %3 Binding 0
OpDecorate %4 DescriptorSet 0
OpDecorate %4 Binding 1
%float = OpTypeFloat 32
%6 = OpTypeImage %float Cube 0 0 0 1 Unknown
%_ptr_UniformConstant_6 = OpTypePointer UniformConstant %6
%3 = OpVariable %_ptr_UniformConstant_6 UniformConstant
%8 = OpTypeSampler
%_ptr_UniformConstant_8 = OpTypePointer UniformConstant %8
%4 = OpVariable %_ptr_UniformConstant_8 UniformConstant
%void = OpTypeVoid
%11 = OpTypeFunction %void
%v3float = OpTypeVector %float 3
%_ptr_Private_v3float = OpTypePointer Private %v3float
%13 = OpVariable %_ptr_Private_v3float Private
%v4float = OpTypeVector %float 4
%_ptr_Private_v4float = OpTypePointer Private %v4float
%16 = OpVariable %_ptr_Private_v4float Private
%float_1 = OpConstant %float 1
%float_0 = OpConstant %float 0
%25 = OpTypeSampledImage %6
%1 = OpFunction %void None %11
%18 = OpLabel
%21 = OpCompositeConstruct %v3float %float_1 %float_0 %float_0
OpStore %13 %21
%22 = OpLoad %v3float %13
%23 = OpLoad %6 %3
%24 = OpLoad %8 %4
%26 = OpSampledImage %25 %23 %24
%27 = OpImageSampleExplicitLod %v4float %26 %22 Lod %float_0
OpStore %16 %27
OpReturn
OpFunctionEnd
