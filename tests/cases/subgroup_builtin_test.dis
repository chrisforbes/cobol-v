OpCapability Shader
OpCapability GroupNonUniform
%2 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint GLCompute %1 "MAIN" %SubgroupId %SubgroupSize
OpExecutionMode %1 LocalSize 64 1 1
OpDecorate %SubgroupId BuiltIn SubgroupId
OpDecorate %SubgroupSize BuiltIn SubgroupSize
%void = OpTypeVoid
%6 = OpTypeFunction %void
%uint = OpTypeInt 32 0
%_ptr_Input_uint = OpTypePointer Input %uint
%SubgroupId = OpVariable %_ptr_Input_uint Input
%SubgroupSize = OpVariable %_ptr_Input_uint Input
%_ptr_Private_uint = OpTypePointer Private %uint
%9 = OpVariable %_ptr_Private_uint Private
%11 = OpVariable %_ptr_Private_uint Private
%1 = OpFunction %void None %6
%12 = OpLabel
%13 = OpLoad %uint %SubgroupId
OpStore %9 %13
%14 = OpLoad %uint %SubgroupSize
OpStore %11 %14
OpReturn
OpFunctionEnd
