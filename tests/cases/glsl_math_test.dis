OpCapability Shader
%2 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint GLCompute %1 "MAIN"
OpExecutionMode %1 LocalSize 1 1 1
%void = OpTypeVoid
%4 = OpTypeFunction %void
%float = OpTypeFloat 32
%_ptr_Private_float = OpTypePointer Private %float
%float_1 = OpConstant %float 1
%6 = OpVariable %_ptr_Private_float Private %float_1
%9 = OpVariable %_ptr_Private_float Private
%10 = OpVariable %_ptr_Private_float Private
%int = OpTypeInt 32 1
%_ptr_Private_int = OpTypePointer Private %int
%12 = OpVariable %_ptr_Private_int Private
%_struct_18 = OpTypeStruct %float %int
%1 = OpFunction %void None %4
%14 = OpLabel
%15 = OpLoad %float %6
%16 = OpExtInst %float %2 Sin %15
OpStore %9 %16
%17 = OpLoad %float %6
%19 = OpExtInst %_struct_18 %2 FrexpStruct %17
%20 = OpCompositeExtract %float %19 0
OpStore %10 %20
%21 = OpCompositeExtract %int %19 1
OpStore %12 %21
OpReturn
OpFunctionEnd
