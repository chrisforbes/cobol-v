OpCapability Shader
OpCapability Sampled1D
OpCapability Image1D
OpCapability ImageQuery
%2 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint GLCompute %1 "MAIN"
OpExecutionMode %1 LocalSize 64 1 1
OpDecorate %3 DescriptorSet 0
OpDecorate %3 Binding 0
OpDecorate %4 DescriptorSet 0
OpDecorate %4 Binding 1
OpDecorate %5 DescriptorSet 0
OpDecorate %5 Binding 2
%float = OpTypeFloat 32
%7 = OpTypeImage %float 1D 0 0 0 2 R32f
%_ptr_UniformConstant_7 = OpTypePointer UniformConstant %7
%3 = OpVariable %_ptr_UniformConstant_7 UniformConstant
%9 = OpTypeImage %float 2D 0 0 0 2 Rgba32f
%_ptr_UniformConstant_9 = OpTypePointer UniformConstant %9
%4 = OpVariable %_ptr_UniformConstant_9 UniformConstant
%11 = OpTypeImage %float 3D 0 0 0 2 Rgba32f
%_ptr_UniformConstant_11 = OpTypePointer UniformConstant %11
%5 = OpVariable %_ptr_UniformConstant_11 UniformConstant
%void = OpTypeVoid
%14 = OpTypeFunction %void
%int = OpTypeInt 32 1
%_ptr_Private_int = OpTypePointer Private %int
%16 = OpVariable %_ptr_Private_int Private
%v2int = OpTypeVector %int 2
%_ptr_Private_v2int = OpTypePointer Private %v2int
%19 = OpVariable %_ptr_Private_v2int Private
%v3int = OpTypeVector %int 3
%_ptr_Private_v3int = OpTypePointer Private %v3int
%22 = OpVariable %_ptr_Private_v3int Private
%1 = OpFunction %void None %14
%24 = OpLabel
%25 = OpLoad %7 %3
%26 = OpImageQuerySize %int %25
OpStore %16 %26
%27 = OpLoad %9 %4
%28 = OpImageQuerySize %v2int %27
OpStore %19 %28
%29 = OpLoad %11 %5
%30 = OpImageQuerySize %v3int %29
OpStore %22 %30
OpReturn
OpFunctionEnd
