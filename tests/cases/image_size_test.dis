OpCapability Shader
OpCapability ImageQuery
%2 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint GLCompute %1 "MAIN"
OpExecutionMode %1 LocalSize 64 1 1
OpDecorate %3 DescriptorSet 0
OpDecorate %3 Binding 0
%float = OpTypeFloat 32
%5 = OpTypeImage %float 2D 0 0 0 2 Rgba32f
%_ptr_UniformConstant_5 = OpTypePointer UniformConstant %5
%3 = OpVariable %_ptr_UniformConstant_5 UniformConstant
%void = OpTypeVoid
%8 = OpTypeFunction %void
%int = OpTypeInt 32 1
%v2int = OpTypeVector %int 2
%_ptr_Private_v2int = OpTypePointer Private %v2int
%11 = OpVariable %_ptr_Private_v2int Private
%1 = OpFunction %void None %8
%13 = OpLabel
%14 = OpLoad %5 %3
%15 = OpImageQuerySize %v2int %14
OpStore %11 %15
OpReturn
OpFunctionEnd
